import { VerticalBox, HorizontalBox, Palette, CheckBox, Button } from "std-widgets.slint";

struct VizLabel {
    text: string,
    screen-x: float,
    screen-y: float,
    label-color: color,
}

struct CopterInfo {
    id: int,
    state-name: string,
    battery-voltage: string,
    battery-level: float,
    rssi-text: string,
    link-quality: float,
    alive: bool,
    selected: bool,
    color: color,
}

export component AppWindow inherits Window {
    title: "Swarm Control Tower";
    preferred-width: 1200px;
    preferred-height: 800px;
    background: Palette.background;

    // 3D viewport
    in-out property <image> texture;
    out property <float> viewport-width: viz.width / 1px;
    out property <float> viewport-height: viz.height / 1px;

    // Camera state
    in-out property <float> cam-yaw: 0.8;
    in-out property <float> cam-pitch: 0.6;
    in-out property <float> cam-distance: 6.0;
    in-out property <float> cam-pan-x: 0;
    in-out property <float> cam-pan-y: 0;

    // Toggle states
    in-out property <bool> show-cf-labels: true;
    in-out property <bool> show-axis-labels: false;
    in-out property <bool> show-grid-labels: true;
    in-out property <bool> show-base-stations: false;
    in-out property <bool> show-axes: false;
    in-out property <bool> show-grid: true;
    in-out property <bool> show-goto-history: true;
    in-out property <bool> auto-rotate: false;
    in-out property <bool> show-fog: false;
    in-out property <[VizLabel]> cf-labels;
    in-out property <[VizLabel]> axis-labels;
    in-out property <[VizLabel]> grid-labels;

    // Selection
    in-out property <int> selected-copter: -1;

    // Status
    in-out property <string> radio-status: "Disconnected";
    in-out property <int> desired-flying: 0;
    in-out property <int> max-wand-grasped: 255;
    in-out property <bool> force-takeoff: false;
    in-out property <[CopterInfo]> copters;

    // Control callbacks
    callback request-more();
    callback request-less();
    callback request-all();
    callback request-none();
    callback request-more-wand();
    callback request-less-wand();
    callback request-all-wand();
    callback request-none-wand();
    callback clear-trail(int);
    callback emergency-stop(int);
    callback emergency-stop-all();

    HorizontalLayout {
        // Side panel - copter list (left)
        Rectangle {
            width: 260px;
            background: Palette.alternate-background;
            border-width: 1px;
            border-color: Palette.border;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;

                HorizontalLayout {
                    Text {
                        text: "Swarm Status";
                        font-size: 16px;
                        font-weight: 700;
                        color: Palette.foreground;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: "Target: " + root.desired-flying;
                        font-size: 11px;
                        color: Palette.foreground.transparentize(0.4);
                        vertical-alignment: center;
                    }
                }

                // Control buttons
                HorizontalLayout {
                    spacing: 4px;
                    Button {
                        text: "+";
                        horizontal-stretch: 1;
                        clicked => { root.request-more(); }
                    }
                    Button {
                        text: "-";
                        horizontal-stretch: 1;
                        clicked => { root.request-less(); }
                    }
                    Button {
                        text: "All";
                        horizontal-stretch: 1;
                        clicked => { root.request-all(); }
                    }
                    Button {
                        text: "None";
                        horizontal-stretch: 1;
                        clicked => { root.request-none(); }
                    }
                }

                CheckBox {
                    text: "Force takeoff (low battery)";
                    checked <=> root.force-takeoff;
                }

                HorizontalLayout {
                    Text {
                        text: "Max Wand Grasped";
                        font-size: 12px;
                        font-weight: 600;
                        color: Palette.foreground;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.max-wand-grasped == 255 ? "All" : root.max-wand-grasped + "";
                        font-size: 11px;
                        color: Palette.foreground.transparentize(0.4);
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 4px;
                    Button {
                        text: "+";
                        horizontal-stretch: 1;
                        clicked => { root.request-more-wand(); }
                    }
                    Button {
                        text: "-";
                        horizontal-stretch: 1;
                        clicked => { root.request-less-wand(); }
                    }
                    Button {
                        text: "All";
                        horizontal-stretch: 1;
                        clicked => { root.request-all-wand(); }
                    }
                    Button {
                        text: "None";
                        horizontal-stretch: 1;
                        clicked => { root.request-none-wand(); }
                    }
                }

                // Emergency Stop All
                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: estop-all-touch.has-hover ? #901818 : #c02020;

                    estop-all-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { estop-confirm.show(); }
                    }

                    Text {
                        width: 100%;
                        height: 100%;
                        text: "EMERGENCY STOP ALL";
                        font-size: 11px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    estop-confirm := PopupWindow {
                        x: 0px;
                        y: 40px;
                        width: 240px;

                        Rectangle {
                            width: 240px;
                            background: Palette.background;
                            border-width: 2px;
                            border-color: #c02020;
                            border-radius: 4px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    text: "All flying drones will fall from the sky.";
                                    font-size: 11px;
                                    color: #e04040;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Are you sure?";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Palette.foreground;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    Rectangle {
                                        height: 28px;
                                        horizontal-stretch: 1;
                                        border-radius: 3px;
                                        background: confirm-touch.has-hover ? #901818 : #c02020;

                                        confirm-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.emergency-stop-all();
                                                estop-confirm.close();
                                            }
                                        }

                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: "STOP ALL";
                                            font-size: 11px;
                                            font-weight: 700;
                                            color: #ffffff;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Rectangle {
                                        height: 28px;
                                        horizontal-stretch: 1;
                                        border-radius: 3px;
                                        background: cancel-touch.has-hover ? Palette.background.darker(0.1) : Palette.background.darker(0.03);
                                        border-width: 1px;
                                        border-color: Palette.border;

                                        cancel-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { estop-confirm.close(); }
                                        }

                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: "Cancel";
                                            font-size: 11px;
                                            color: Palette.foreground;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Palette.border;
                }

                // Copter list
                for copter in root.copters: Rectangle {
                    height: 64px;
                    background: copter.selected ? Palette.accent-background :
                                touch.has-hover ? Palette.background.darker(0.06) :
                                copter.alive ? Palette.background.darker(0.03) : Palette.background;
                    border-radius: 4px;
                    border-width: copter.selected ? 1px : 0px;
                    border-color: copter.color;

                    touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if (root.selected-copter == copter.id) {
                                root.selected-copter = -1;
                            } else {
                                root.selected-copter = copter.id;
                            }
                        }
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.up && e.button == PointerEventButton.right) {
                                copter-context-menu.show();
                            }
                        }
                    }

                    copter-context-menu := PopupWindow {
                        x: 10px;
                        y: 40px;
                        width: 140px;

                        Rectangle {
                            width: 140px;
                            background: Palette.background;
                            border-width: 1px;
                            border-color: Palette.border;
                            border-radius: 4px;

                            VerticalLayout {
                                padding: 4px;
                                spacing: 2px;

                                Rectangle {
                                    height: 28px;
                                    border-radius: 3px;
                                    background: menu-touch.has-hover ? Palette.accent-background : transparent;

                                    menu-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.clear-trail(copter.id);
                                        }
                                    }

                                    Text {
                                        x: 8px;
                                        text: "Clear trail";
                                        font-size: 12px;
                                        color: Palette.foreground;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: Palette.border.transparentize(0.5);
                                }

                                Rectangle {
                                    height: 28px;
                                    border-radius: 3px;
                                    background: estop-touch.has-hover ? #c02020 : transparent;

                                    estop-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.emergency-stop(copter.id);
                                        }
                                    }

                                    Text {
                                        x: 8px;
                                        text: "Emergency Stop";
                                        font-size: 12px;
                                        color: estop-touch.has-hover ? #ffffff : #e04040;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        padding: 8px;
                        spacing: 8px;

                        // Color indicator
                        Rectangle {
                            width: 12px;
                            height: 12px;
                            border-radius: 6px;
                            background: copter.color;
                            y: (parent.height - self.height) / 2;
                        }

                        VerticalLayout {
                            spacing: 2px;
                            alignment: center;
                            horizontal-stretch: 1;

                            Text {
                                text: "CF #" + copter.id;
                                font-size: 13px;
                                font-weight: 600;
                                color: copter.alive ? Palette.foreground : Palette.foreground.transparentize(0.5);
                            }
                            Text {
                                text: copter.state-name;
                                font-size: 10px;
                                color: copter.alive ? Palette.foreground.transparentize(0.3) : Palette.foreground.transparentize(0.6);
                            }
                        }

                        // Battery + Link quality bars
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;

                            // Battery bar
                            Rectangle {
                                width: 44px;
                                height: 10px;
                                border-radius: 2px;
                                background: Palette.background.darker(0.15);

                                Rectangle {
                                    x: 2px;
                                    y: 2px;
                                    height: parent.height - 4px;
                                    width: max(0px, (parent.width - 4px) * copter.battery-level);
                                    border-radius: 1px;
                                    background: copter.battery-level < 0.2 ? #e04040 :
                                                copter.battery-level < 0.5 ? #e0a020 : #60c040;
                                }
                            }
                            Text {
                                text: copter.battery-voltage;
                                font-size: 8px;
                                horizontal-alignment: center;
                                color: copter.alive ? Palette.foreground.transparentize(0.4) : Palette.foreground.transparentize(0.7);
                            }

                            // Link quality bar
                            Rectangle {
                                width: 44px;
                                height: 10px;
                                border-radius: 2px;
                                background: Palette.background.darker(0.15);

                                Rectangle {
                                    x: 2px;
                                    y: 2px;
                                    height: parent.height - 4px;
                                    width: max(0px, (parent.width - 4px) * copter.link-quality);
                                    border-radius: 1px;
                                    background: copter.link-quality < 0.3 ? #e04040 :
                                                copter.link-quality < 0.6 ? #e0a020 : #4090e0;
                                }
                            }
                            Text {
                                text: copter.rssi-text;
                                font-size: 8px;
                                horizontal-alignment: center;
                                color: copter.alive ? Palette.foreground.transparentize(0.4) : Palette.foreground.transparentize(0.7);
                            }
                        }
                    }
                }
            }
        }

        // 3D viewport area
        viz := Rectangle {
            horizontal-stretch: 1;
            background: Palette.background;

            Image {
                source: root.texture;
                width: 100%;
                height: 100%;
                image-fit: fill;
            }

            // Label overlays
            Rectangle {
                width: 100%;
                height: 100%;
                if root.show-cf-labels: Rectangle {
                    width: 100%;
                    height: 100%;
                    for label in root.cf-labels: Text {
                        x: label.screen-x * 1px;
                        y: label.screen-y * 1px;
                        text: label.text;
                        font-size: 11px;
                        color: label.label-color;
                    }
                }
                if root.show-axis-labels: Rectangle {
                    width: 100%;
                    height: 100%;
                    for label in root.axis-labels: Text {
                        x: label.screen-x * 1px;
                        y: label.screen-y * 1px;
                        text: label.text;
                        font-size: 12px;
                        font-weight: 700;
                        color: label.label-color;
                    }
                }
                if root.show-grid-labels: Rectangle {
                    width: 100%;
                    height: 100%;
                    for label in root.grid-labels: Text {
                        x: label.screen-x * 1px;
                        y: label.screen-y * 1px;
                        text: label.text;
                        font-size: 10px;
                        color: label.label-color;
                    }
                }
            }

            // Camera controls
            TouchArea {
                property <float> prev-x;
                property <float> prev-y;
                property <bool> dragging;
                property <bool> right-button;
                property <bool> right-click-moved;

                scroll-event(e) => {
                    if (e.delta-y > 0) {
                        root.cam-distance = max(1.0, root.cam-distance - 0.5);
                    } else if (e.delta-y < 0) {
                        root.cam-distance = min(20.0, root.cam-distance + 0.5);
                    }
                    accept
                }

                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        self.prev-x = self.mouse-x / 1px;
                        self.prev-y = self.mouse-y / 1px;
                        self.dragging = true;
                        self.right-button = e.button == PointerEventButton.right || e.button == PointerEventButton.middle;
                        if (e.button == PointerEventButton.right) {
                            self.right-click-moved = false;
                        }
                    } else if (e.kind == PointerEventKind.up) {
                        if (e.button == PointerEventButton.right && !self.right-click-moved) {
                            context-menu.show();
                        }
                        self.dragging = false;
                    }
                }

                moved => {
                    if (self.dragging && self.pressed) {
                        if (self.right-button) {
                            self.right-click-moved = true;
                            root.cam-pan-x += (self.mouse-x / 1px - self.prev-x) * 0.01;
                            root.cam-pan-y -= (self.mouse-y / 1px - self.prev-y) * 0.01;
                        } else {
                            root.cam-yaw -= (self.mouse-x / 1px - self.prev-x) * 0.01;
                            root.cam-pitch = clamp(root.cam-pitch + (self.mouse-y / 1px - self.prev-y) * 0.01, 0.1, 1.5);
                        }
                    }
                    self.prev-x = self.mouse-x / 1px;
                    self.prev-y = self.mouse-y / 1px;
                }
            }

            context-menu := PopupWindow {
                x: 10px;
                y: 10px;
                width: 220px;

                Rectangle {
                    width: 220px;
                    background: Palette.background;
                    border-width: 1px;
                    border-color: Palette.border;
                    border-radius: 4px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        Text {
                            text: "Show Labels";
                            font-size: 12px;
                            font-weight: 600;
                            color: Palette.foreground.transparentize(0.3);
                        }

                        CheckBox {
                            text: "Crazyflie names";
                            checked <=> root.show-cf-labels;
                        }

                        Rectangle {
                            height: 1px;
                            background: Palette.border.transparentize(0.5);
                        }

                        CheckBox {
                            text: "Axis labels (X, Y, Z)";
                            checked <=> root.show-axis-labels;
                        }

                        CheckBox {
                            text: "Grid measurements (m)";
                            checked <=> root.show-grid-labels;
                        }

                        Rectangle {
                            height: 1px;
                            background: Palette.border.transparentize(0.5);
                        }

                        CheckBox {
                            text: "Lighthouse base stations";
                            checked <=> root.show-base-stations;
                        }

                        CheckBox {
                            text: "Axes (X, Y, Z)";
                            checked <=> root.show-axes;
                        }

                        CheckBox {
                            text: "Measurement grid";
                            checked <=> root.show-grid;
                        }

                        Rectangle {
                            height: 1px;
                            background: Palette.border.transparentize(0.5);
                        }

                        CheckBox {
                            text: "Goto history (selected)";
                            checked <=> root.show-goto-history;
                        }

                        CheckBox {
                            text: "Auto-rotate";
                            checked <=> root.auto-rotate;
                        }

                        CheckBox {
                            text: "Depth fog";
                            checked <=> root.show-fog;
                        }
                    }
                }
            }

            // Status overlay
            Rectangle {
                x: 8px;
                y: 8px;
                width: status-text.preferred-width + 16px;
                height: status-text.preferred-height + 8px;
                background: black.transparentize(0.5);
                border-radius: 4px;

                status-text := Text {
                    x: 8px;
                    y: 4px;
                    text: "Radio: " + root.radio-status;
                    font-size: 12px;
                    color: root.radio-status == "Receiving" ? #4ad980 : #f04545;
                }
            }
        }
    }
}
